DESCRIPTION >
    Cars Traffic Measurements. Generated from https://geoportal.valencia.es/apps/OpenData/Trafico/tra_espiras_p.json

SCHEMA >
    `last_edited_date` DateTime `json:$.last_edited_date`,
    `idpm` Int32 `json:$.idpm`,
    `ih` Nullable(Int32) `json:$.ih`,
    `geo_point_2d` String `json:$.geo_point_2d`

ENGINE "MergeTree"
ENGINE_SORTING_KEY "last_edited_date, idpm"

FORWARD_QUERY >
    SELECT last_edited_date, idpm, ih, geo_point_2d
